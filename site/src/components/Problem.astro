---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const problems = [
  { title: t.problem1Title, desc: t.problem1Desc, icon: 'explosion' },
  { title: t.problem2Title, desc: t.problem2Desc, icon: 'broken' },
  { title: t.problem3Title, desc: t.problem3Desc, icon: 'question' },
  { title: t.problem4Title, desc: t.problem4Desc, icon: 'clock' },
];
---

<section class="section problem">
  <div class="container">
    <h2 class="section-title fade-in">{t.problemTitle}</h2>
    <p class="section-subtitle fade-in delay-1">{t.problemSubtitle}</p>

    <div class="problem-grid">
      {problems.map((p, i) => (
        <div class={`problem-card fade-in delay-${i + 1}`}>
          <div class="problem-icon" data-icon={p.icon}>
            {p.icon === 'explosion' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            )}
            {p.icon === 'broken' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M16 16s-1.5-2-4-2-4 2-4 2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            )}
            {p.icon === 'question' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            )}
            {p.icon === 'clock' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            )}
          </div>
          <h3 class="problem-title">{p.title}</h3>
          <p class="problem-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problem {
    border-top: 1px solid var(--border);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .problem-card {
    padding: 28px;
    border-radius: var(--radius-lg);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }
  .problem-card:hover {
    border-color: rgba(239, 68, 68, 0.3);
  }

  .problem-icon {
    color: var(--danger);
    margin-bottom: 14px;
    opacity: 0.8;
  }

  .problem-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .problem-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
