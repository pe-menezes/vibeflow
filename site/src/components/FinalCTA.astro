---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<div class="cta reveal">
  <div class="container cta-inner">
    <h2 class="cta-title">{t.ctaTitle2}</h2>
    <div class="cta-badges">
      <span class="cta-badge">{t.ctaBadgeOS}</span>
      <span class="cta-badge">{t.ctaBadgeMIT}</span>
      <span class="cta-badge">{t.ctaBadgeFree}</span>
    </div>
    <a href="https://github.com/pe-menezes/vibeflow" target="_blank" rel="noopener" class="btn btn-dark">{t.ctaGithub}</a>
    <p class="cta-credit">{t.ctaCreator}</p>
  </div>
</div>

<style>
  .cta {
    text-align: center;
    padding: 2rem 2rem 1.5rem;
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .cta-badges {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .cta-badge {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-secondary);
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
  }

  .cta-credit {
    margin-top: 1rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
</style>
