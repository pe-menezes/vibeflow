---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero">
  <canvas id="wave-canvas"></canvas>
  <div class="hero-content">
    <span class="hero-eyebrow">{t.heroEyebrow}</span>
    <h1>
      <Fragment set:html={t.heroTitle.replace('\n', '<br />')} />
    </h1>
    <p class="hero-sub">{t.heroSubtitle}</p>

    <div class="terminal">
      <div class="terminal-bar">
        <span class="dot dot-r"></span>
        <span class="dot dot-y"></span>
        <span class="dot dot-g"></span>
        <span class="terminal-label">{t.heroQuickStartTitle}</span>
      </div>
      <div class="terminal-body">
        <div class="line">
          <span class="p">$</span>
          <span class="c">analyze</span>
          <span class="o">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&rarr; {t.heroQuickStart1Desc}</span>
        </div>
        <div class="line">
          <span class="p">$</span>
          <span class="c">gen-spec "auth"</span>
          <span class="o">&nbsp;&rarr; {t.heroQuickStart2Desc}</span>
        </div>
        <div class="line">
          <span class="p">$</span>
          <span class="c">implement</span>
          <span class="o">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&rarr; {t.heroQuickStart3Desc}</span>
        </div>
        <div class="line">
          <span class="p">$</span>
          <span class="c">audit</span>
          <span class="o">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&rarr; </span>
          <span class="pass">{t.heroQuickStart4Desc}</span>
        </div>
      </div>
    </div>

    <div class="hero-actions">
      <a href={`/${lang}/#how`} class="btn btn-dark">{t.heroCta}</a>
      <a href={`/${lang}/#editions`} class="btn btn-light">{t.heroInstall}</a>
    </div>
  </div>
</section>

<script>
  // Perlin Noise
  class Perlin {
    p: Uint8Array;
    constructor() {
      const p = [151,160,137,91,90,15,131,13,201,95,96,53,194,233,7,225,140,36,103,30,69,142,8,99,37,240,21,10,23,190,6,148,247,120,234,75,0,26,197,62,94,252,219,203,117,35,11,32,57,177,33,88,237,149,56,87,174,20,125,136,171,168,68,175,74,165,71,134,139,48,27,166,77,146,158,231,83,111,229,122,60,211,133,230,220,105,92,41,55,46,245,40,244,102,143,54,65,25,63,161,1,216,80,73,209,76,132,187,208,89,18,169,200,196,135,130,116,188,159,86,164,100,109,198,173,186,3,64,52,217,226,250,124,123,5,202,38,147,118,126,255,82,85,212,207,206,59,227,47,16,58,17,182,189,28,42,223,183,170,213,119,248,152,2,44,154,163,70,221,153,101,155,167,43,172,9,129,22,39,253,19,98,108,110,79,113,224,232,178,185,112,104,218,246,97,228,251,34,242,193,238,210,144,12,191,179,162,241,81,51,145,235,249,14,239,107,49,192,214,31,181,199,106,157,184,84,204,176,115,121,50,45,127,4,150,254,138,236,205,93,222,114,67,29,24,72,243,141,128,195,78,66,215,61,156,180];
      this.p = new Uint8Array(512);
      for (let i = 0; i < 256; i++) { this.p[i] = p[i]; this.p[i+256] = p[i]; }
    }
    fade(t: number) { return t*t*t*(t*(t*6-15)+10); }
    lerp(t: number, a: number, b: number) { return a+t*(b-a); }
    grad(h: number, x: number, y: number) { const s=h&3; return(s===0?x+y:s===1?-x+y:s===2?x-y:-x-y); }
    noise(x: number, y: number) {
      const xi=Math.floor(x)&255, yi=Math.floor(y)&255;
      const xf=x-Math.floor(x), yf=y-Math.floor(y);
      const u=this.fade(xf), v=this.fade(yf);
      const aa=this.p[this.p[xi]+yi], ba=this.p[this.p[xi+1]+yi];
      const ab=this.p[this.p[xi]+yi+1], bb=this.p[this.p[xi+1]+yi+1];
      return this.lerp(v,
        this.lerp(u, this.grad(aa,xf,yf), this.grad(ba,xf-1,yf)),
        this.lerp(u, this.grad(ab,xf,yf-1), this.grad(bb,xf-1,yf-1))
      );
    }
  }

  // Wave Animation
  (function() {
    const canvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const perlin = new Perlin();
    const isMobile = window.innerWidth < 768;
    const dpr = isMobile ? 1 : Math.min(window.devicePixelRatio || 1, 2);

    let w: number, h: number;
    let mouseX = -9999, mouseY = -9999, tMouseX = -9999, tMouseY = -9999, active = false;

    function resize() {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      canvas.style.width = w + 'px'; canvas.style.height = h + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    document.addEventListener('mousemove', e => { tMouseX = e.clientX; tMouseY = e.clientY; active = true; });
    document.addEventListener('mouseleave', () => { active = false; });

    const LINES = isMobile ? 14 : 24;
    const MOUSE_R = 160;
    const MOUSE_FORCE = 25;
    let time = 0;

    function frame() {
      ctx!.clearRect(0, 0, w, h);
      time += 0.005;

      if (active) {
        mouseX += (tMouseX - mouseX) * 0.04;
        mouseY += (tMouseY - mouseY) * 0.04;
      } else {
        mouseX += (-9999 - mouseX) * 0.015;
        mouseY += (-9999 - mouseY) * 0.015;
      }

      ctx!.lineCap = 'round';

      for (let i = 0; i < LINES; i++) {
        const t = i / (LINES - 1);
        const baseY = h * 0.08 + t * h * 0.84;
        const center = 1 - Math.abs(t - 0.5) * 2;
        const alpha = 0.05 + center * center * 0.28;
        const lw = 0.6 + center * 2.0;
        const hue = 240 + t * 25;
        const sat = 55 + center * 25;
        const lit = 62 + (1 - center) * 14;

        ctx!.beginPath();
        const step = isMobile ? 8 : 4;
        let prevX = 0, prevY = 0;

        for (let x = -step; x <= w + step; x += step) {
          const sx = x / w;
          const n1 = perlin.noise(sx * 2.5 + i * 0.6, time + i * 0.25);
          const n2 = perlin.noise(sx * 5 + i * 1.1 + 40, time * 1.8 + i * 0.4);
          let waveY = n1 * 50 + n2 * 14;

          const dx = x - mouseX;
          const dy = (baseY + waveY) - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < MOUSE_R) {
            const f = 1 - dist / MOUSE_R;
            waveY += (dy / (dist || 1)) * f * f * f * MOUSE_FORCE;
          }

          const y = baseY + waveY;
          if (x <= 0) {
            ctx!.moveTo(x, y);
            prevX = x; prevY = y;
          } else {
            const cpX = (prevX + x) / 2;
            const cpY = (prevY + y) / 2;
            ctx!.quadraticCurveTo(prevX, prevY, cpX, cpY);
            prevX = x; prevY = y;
          }
        }

        ctx!.strokeStyle = `hsla(${hue}, ${sat}%, ${lit}%, ${alpha})`;
        ctx!.lineWidth = lw;
        ctx!.stroke();
      }

      requestAnimationFrame(frame);
    }
    frame();
  })();
</script>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 1.5rem 2rem;
    overflow: hidden;
  }

  #wave-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 780px;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 7.5vw, 5.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    color: var(--text-secondary);
    font-weight: 400;
    line-height: 1.5;
    max-width: 520px;
    margin: 0 auto 1.75rem;
  }

  /* Terminal */
  .terminal {
    background: var(--bg-code);
    border-radius: 12px;
    max-width: 560px;
    margin: 0 auto 2rem;
    overflow: hidden;
    text-align: left;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.10), 0 0 0 0.5px rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.5s var(--ease-out), transform 0.5s var(--ease-out);
  }
  .terminal:hover {
    box-shadow: 0 24px 80px rgba(99, 102, 241, 0.12), 0 0 0 0.5px rgba(99, 102, 241, 0.15);
    transform: translateY(-2px);
  }

  .terminal-bar {
    padding: 11px 14px;
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.04);
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .terminal-label {
    margin-left: 6px;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.25);
    font-family: var(--font-mono);
  }

  .terminal-body {
    padding: 1.1rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 2.1;
  }

  .terminal-body .line {
    opacity: 0;
    animation: tIn 0.4s var(--ease-out) forwards;
  }
  .terminal-body .line:nth-child(1) { animation-delay: 0.2s; }
  .terminal-body .line:nth-child(2) { animation-delay: 0.5s; }
  .terminal-body .line:nth-child(3) { animation-delay: 0.8s; }
  .terminal-body .line:nth-child(4) { animation-delay: 1.1s; }

  @keyframes tIn {
    from { opacity: 0; transform: translateY(3px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .terminal-body .p { color: #818cf8; }
  .terminal-body .c { color: #e5e5ea; }
  .terminal-body .o { color: #8e8e93; }
  .terminal-body .pass { color: #30d158; font-weight: 500; }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1.25rem 2rem;
    }
    .terminal-body {
      font-size: 0.65rem;
      padding: 0.8rem 1rem;
      line-height: 1.9;
    }
  }
</style>
