---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const steps = [
  { num: '1', title: t.step1Title, desc: t.pipelineStep1Desc },
  { num: '2', title: t.step2Title, desc: t.pipelineStep2Desc },
  { num: '3', title: t.step3Title, desc: t.pipelineStep3Desc },
  { num: '4', title: t.step4Title, desc: t.pipelineStep4Desc },
];
---

<div class="section" id="how">
  <div class="container">
    <div class="section-label">{t.pipelineLabel}</div>
    <h2 class="section-title" set:html={t.howTitle} />
    <p class="section-sub">{t.howSubtitle}</p>

    <div class="pipeline">
      {steps.map((step) => (
        <div class="pipe-step">
          <div class="pipe-num">{step.num}</div>
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </div>
      ))}
    </div>

    <div class="pipe-extra">
      <strong>{t.pipelineExtra}</strong> {t.pipelineExtraList}
      <a href={`/${lang}/commands`} class="pipe-link">{t.featSeeAll}</a>
    </div>
  </div>
</div>

<style>
  .pipeline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
  }

  @media (min-width: 769px) {
    .pipeline::before {
      content: '';
      position: absolute;
      top: 27px;
      left: 40px;
      right: 40px;
      height: 2px;
      background: linear-gradient(90deg, transparent 0%, rgba(99, 102, 241, 0.25) 15%, rgba(99, 102, 241, 0.4) 50%, rgba(99, 102, 241, 0.25) 85%, transparent 100%);
      border-radius: 2px;
    }
  }

  .pipe-step {
    text-align: left;
  }

  .pipe-num {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--accent);
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .pipe-step h3 {
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .pipe-step p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .pipe-extra {
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .pipe-extra strong {
    color: var(--text-secondary);
    font-weight: 600;
  }

  .pipe-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
  }
  .pipe-link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .pipeline {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
