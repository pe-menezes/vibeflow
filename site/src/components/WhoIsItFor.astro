---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const personas = [
  {
    title: t.who1Title,
    desc: t.who1Desc,
    icon: 'code',
  },
  {
    title: t.who2Title,
    desc: t.who2Desc,
    icon: 'team',
  },
  {
    title: t.who3Title,
    desc: t.who3Desc,
    icon: 'clipboard',
  },
];
---

<section class="section who">
  <div class="container">
    <h2 class="section-title fade-in">{t.whoTitle}</h2>

    <div class="personas">
      {personas.map((p, i) => (
        <div class={`persona-card fade-in delay-${i + 1}`}>
          <div class="persona-icon">
            {p.icon === 'code' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            )}
            {p.icon === 'team' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            )}
            {p.icon === 'clipboard' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
            )}
          </div>
          <h3 class="persona-title">{p.title}</h3>
          <p class="persona-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .who {
    border-top: 1px solid var(--border);
    background: var(--bg-secondary);
  }

  .personas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .persona-card {
    padding: 28px;
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
    border: 1px solid var(--border);
    text-align: center;
    transition: border-color 0.2s;
  }
  .persona-card:hover {
    border-color: var(--border-light);
  }

  .persona-icon {
    color: var(--accent-light);
    margin-bottom: 16px;
    display: flex;
    justify-content: center;
  }

  .persona-title {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .persona-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .personas {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
