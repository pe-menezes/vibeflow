---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const commands = [
  { id: 'analyze', tier: 'Core', title: t.feat1Title, desc: t.feat1Desc, forLabel: t.feat1For, highlights: t.feat1Highlights },
  { id: 'gen-spec', tier: 'Core', title: t.feat2Title, desc: t.feat2Desc, forLabel: t.feat2For, highlights: t.feat2Highlights },
  { id: 'implement', tier: 'Core', title: t.feat3Title, desc: t.feat3Desc, forLabel: t.feat3For, highlights: t.feat3Highlights },
  { id: 'audit', tier: 'Core', title: t.feat4Title, desc: t.feat4Desc, forLabel: t.feat4For, highlights: t.feat4Highlights },
  { id: 'discover', tier: 'Tool', title: t.feat5Title, desc: t.feat5Desc, forLabel: t.feat5For, highlights: t.feat5Highlights },
  { id: 'prompt-pack', tier: 'Tool', title: t.feat6Title, desc: t.feat6Desc, forLabel: t.feat6For, highlights: t.feat6Highlights },
  { id: 'quick', tier: 'Tool', title: t.feat7Title, desc: t.feat7Desc, forLabel: t.feat7For, highlights: t.feat7Highlights },
  { id: 'teach', tier: 'Tool', title: t.feat8Title, desc: t.feat8Desc, forLabel: t.feat8For, highlights: t.feat8Highlights },
  { id: 'stats', tier: 'Tool', title: t.feat9Title, desc: t.feat9Desc, forLabel: t.feat9For, highlights: t.feat9Highlights },
];
---

<div class="section" id="commands">
  <div class="container">
    <div class="section-label">{t.cmdLabel}</div>
    <h2 class="section-title">{t.cmdGridTitle}</h2>
    <p class="section-sub">{t.featuresSubtitle}</p>

    <div class="cmd-grid">
      {commands.map((cmd) => (
        <div class="cmd-card">
          <div class={`cmd-tier ${cmd.tier.toLowerCase()}`}>{cmd.tier}</div>
          <div class="cmd-name">{cmd.title}</div>
          <div class="cmd-for">{cmd.forLabel}</div>
          <p>{cmd.desc}</p>
          <div class="cmd-flags">
            {cmd.highlights.map((h: string) => (
              <span class="cmd-flag">{h}</span>
            ))}
          </div>
          <a href={`/${lang}/commands#${cmd.id}`} class="cmd-detail-link">{t.cmdDetails}</a>
        </div>
      ))}
    </div>

    <div class="cmd-cta">
      <a href={`/${lang}/commands`} class="btn btn-light">{t.cmdFullRef}</a>
    </div>
  </div>
</div>

<style>
  .cmd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .cmd-card {
    background: var(--bg-card);
    border-radius: 14px;
    padding: 1.75rem;
    border: 1px solid var(--border);
    transition: all 0.35s var(--ease-out);
  }
  .cmd-card:hover {
    border-color: var(--accent-glow-strong);
    box-shadow: 0 8px 30px rgba(99, 102, 241, 0.08);
    transform: translateY(-3px);
  }

  .cmd-tier {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }
  .cmd-tier.core {
    background: var(--accent-glow);
    color: var(--accent);
  }
  .cmd-tier.tool {
    background: var(--bg-secondary);
    color: var(--text-muted);
  }

  .cmd-name {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .cmd-for {
    font-size: 0.78rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }

  .cmd-card p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .cmd-flags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .cmd-flag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
  }

  .cmd-detail-link {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
  }
  .cmd-detail-link:hover {
    color: var(--text-primary);
  }

  .cmd-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media (max-width: 768px) {
    .cmd-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
