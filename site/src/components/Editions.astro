---
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const editions = [
  { title: t.claudeTitle, desc: t.claudeDesc, install: t.claudeInstall },
  { title: t.cursorTitle, desc: t.cursorDesc, install: t.cursorInstall },
  { title: t.copilotTitle, desc: t.copilotDesc, install: t.copilotInstall },
];
---

<div class="section" id="editions">
  <div class="container">
    <div class="reveal">
      <div class="section-label">{t.editionsLabel}</div>
      <h2 class="section-title">{t.editionsTitle2}</h2>
      <p class="section-sub">{t.editionsSubtitle2}</p>
    </div>

    <div class="ed-wrap reveal">
      <div class="ed-grid">
        {editions.map((ed) => (
          <div class="ed-card">
            <h3>{ed.title}</h3>
            <p class="ed-desc">{ed.desc}</p>
            <div class="ed-cmd">
              <span>{ed.install}</span>
              <button class="copy-btn" data-copy={ed.install} type="button">{t.copyLabel}</button>
            </div>
          </div>
        ))}
      </div>
      <div class="ed-tag">{t.editionsTagline}</div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.copy || '';
      navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = (btn.closest('[data-lang]') as HTMLElement)?.dataset.lang === 'pt-br' ? 'Copiado!' : 'Copied!';
      setTimeout(() => { btn.textContent = orig; }, 1500);
    });
  });
</script>

<style>
  .ed-wrap {
    background: var(--bg-secondary);
    border-radius: 20px;
    padding: 2rem;
  }

  .ed-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ed-card {
    background: var(--bg-card);
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid transparent;
    transition: all 0.35s var(--ease-out);
  }
  .ed-card:hover {
    border-color: var(--accent-glow-strong);
    box-shadow: 0 8px 30px rgba(99, 102, 241, 0.08);
    transform: translateY(-4px);
  }

  .ed-card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .ed-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }

  .ed-cmd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg-secondary);
    border-radius: 10px;
    padding: 0.65rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-primary);
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
    font-family: var(--font-sans);
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    transition: background 0.2s var(--ease-out);
    white-space: nowrap;
  }
  .copy-btn:hover {
    background: var(--accent-glow);
  }

  .ed-tag {
    text-align: center;
    margin-top: 1.25rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .ed-wrap {
      padding: 1.5rem 1.25rem;
    }
    .ed-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
